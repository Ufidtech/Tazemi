# ---------------------------------------------------------------------------
# Frontend environment (Vite). Copy to .env (local) or set in your host/CI.
# All values are exposed to the browser - never put secrets here.
# ---------------------------------------------------------------------------

# API base URL of the backend.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Auth mode: local | backend | firebase | production
#   local      - fake client-side session (no backend), dev only
#   backend    - email/password verified by the backend /auth/login
#   firebase   - Firebase email/password sign-in, backend verifies the ID token
#   production - Firebase only; no local fallback
VITE_AUTH_MODE=firebase

# Firebase web app config (public client keys).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tazemi-e48ba.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://tazemi-e48ba-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=tazemi-e48ba
VITE_FIREBASE_STORAGE_BUCKET=tazemi-e48ba.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
