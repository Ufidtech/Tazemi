# ---------------------------------------------------------------------------
# Backend environment (FastAPI). Copy to backend/.env and fill in real values.
# ---------------------------------------------------------------------------

# Environment: set to "production" to enforce Firebase-only auth and hard-fail
# when required secrets are missing. Leave unset/blank for local development.
APP_ENV=development

# Local dev credential fallback. Allowed automatically outside production.
# In production it stays disabled unless explicitly set to "true".
ALLOW_LOCAL_AUTH=true

# --- Firebase Admin (required for real Firebase login + Realtime DB + Storage) ---
# Provide the service account either as raw JSON or a file path.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account", ...}'
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
FIREBASE_DATABASE_URL=https://tazemi-e48ba-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=tazemi-e48ba
FIREBASE_STORAGE_BUCKET=tazemi-e48ba.firebasestorage.app

# --- Sensitive data encryption (NIN/BVN). REQUIRED in production. ---
# Either a ready Fernet key (AGG_ENCRYPTION_KEY) or any strong secret.
# AGG_ENCRYPTION_KEY=<urlsafe-base64-32-byte-fernet-key>
AGG_ENCRYPTION_SECRET=change-me-to-a-long-random-secret

# --- Role assignment for Firebase-authenticated users (no user DB) ---
# Used as a fallback when a user has no "role" custom claim.
# STAFF_ROLES={"ceo@tazemi.com":"ceo","operator@tazemi.com":"field_operator"}

# --- Backend-credential login (used when VITE_AUTH_MODE=backend) ---
# STAFF_USERS=[{"email":"ceo@tazemi.com","password":"...","name":"CEO","role":"ceo"}]
